# ==========================================
# Resilient Philippines Root .gitignore
# Only tracks custom/modified code files
# ==========================================

# 1. Ignore WordPress Core Folders
/wp-admin/
/wp-includes/
/rp/

# 2. Ignore Root Files
/*.php
/*.html
/*.txt
/.htaccess
/web.config
/.ftpquota

# 3. Ignore wp-content media, cache, and backups
/wp-content/uploads/
/wp-content/cache/
/wp-content/backups/
/wp-content/backups-dup-lite/
/wp-content/upgrade/
/wp-content/upgrade-temp-backup/
/wp-content/wflogs/
/wp-content/gallery/
/wp-content/index.php
/wp-content/plugins/index.php
/wp-content/themes/index.php

# 4. Ignore all plugins except our custom plugin
/wp-content/plugins/*
!/wp-content/plugins/rp-resource-hub/

# 5. Ignore all themes except our custom child theme and modified parent theme
/wp-content/themes/*
!/wp-content/themes/resilient-hub-child/
!/wp-content/themes/foreverwood-premium/

# 6. Ignore backup git folders and archives
**/.git_bak/
**/node_modules/
*.zip
